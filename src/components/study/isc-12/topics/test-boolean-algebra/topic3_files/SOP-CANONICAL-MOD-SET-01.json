            { "step": 9, "action": "Remove duplicates", "expression": "F = A'B'CD' + A'BC'D' + A'BC'D + A'BCD' + A'BCD + ABC'D' + ABC'D + ABCD'", "law": "Idempotent Law" },
            { "step": 10, "action": "Final canonical SOP", "expression": "F = A'B'CD' + A'BC'D' + A'BC'D + A'BCD' + A'BCD + ABC'D' + ABC'D + ABCD'", "law": "Canonical form" }
          ],
          "explanation": "All three product terms are expanded to include all four variables."
        },
        {
          "q": "Convert to canonical SOP form: F(A,B,C,D) = (A ⊕ B)(C ⊕ D)",
