            { "step": 9, "action": "Remove duplicate ABCD", "expression": "F = ABCD + ABCD' + ABC'D + ABC'D' + AB'CD + A'BCD + A'B'CD", "law": "Idempotent Law" },
            { "step": 10, "action": "Final canonical SOP", "expression": "F = A'B'CD + A'BCD + AB'CD + ABCD + ABC'D' + ABC'D + ABCD'", "law": "Canonical form" }
          ],
          "explanation": "Each product term is expanded to include all four variables."
        },
        {
          "q": "Convert to canonical SOP form: F(A,B,C,D) = A'B + BC' + CD'",
