            { "step": 5, "action": "Expand", "expression": "F = A'B·C'D + A'B·CD' + AB'·C'D + AB'·CD'", "law": "Distributive Law" },
            { "step": 6, "action": "Result", "expression": "F = A'BC'D + A'BCD' + AB'C'D + AB'CD'", "law": "Multiplication" },
            { "step": 7, "action": "Check if canonical", "expression": "Each term has all 4 variables", "law": "Observation" },
            { "step": 8, "action": "Already canonical", "expression": "F = A'BC'D + A'BCD' + AB'C'D + AB'CD'", "law": "Canonical SOP" }
