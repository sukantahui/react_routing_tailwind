          "original": "A'B + BC' + CD'",
          "variables": 4,
          "canonical": "A'BC'D' + A'BC'D + A'BCD' + A'BCD + A'B'CD' + A'B'C'D' + AB'C'D' + AB'C'D",
          "minterms": "m4, m5, m6, m7, m2, m0, m8, m9",
          "steps": [
