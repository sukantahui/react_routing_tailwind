{
  "paperId": "SOP-CANONICAL-MOD-SET-01",
  "title": "SOP to Canonical SOP Conversion - Moderate Level",
  "duration": "1.5 Hours",
  "totalMarks": 50,

  "sections": [
    {
      "section": "A",
      "type": "2-Variable SOP to Canonical (2 Marks Each)",
      "marksPerQuestion": 2,
      "totalQuestions": 5,
      "questions": [
        {
          "q": "Convert to canonical SOP form: F(A,B) = A + B",
          "marks": 2,
          "original": "A + B",
          "variables": 2,
          "canonical": "A'B + AB' + AB",
          "minterms": "m1, m2, m3",
          "steps": [
            { "step": 1, "action": "Original expression", "expression": "F = A + B", "law": "Given" },
            { "step": 2, "action": "Multiply missing variable terms", "expression": "A = A(B + B') = AB + AB'", "law": "Identity Law (X = X·1)" },
            { "step": 3, "action": "Similarly for B", "expression": "B = B(A + A') = AB + A'B", "law": "Identity Law" },
            { "step": 4, "action": "Combine all terms", "expression": "F = AB + AB' + AB + A'B", "law": "Substitution" },
            { "step": 5, "action": "Remove duplicate AB", "expression": "F = AB + AB' + A'B", "law": "Idempotent Law (AB + AB = AB)" },
            { "step": 6, "action": "Final canonical SOP", "expression": "F = A'B + AB' + AB", "law": "Canonical form" }
          ],
          "explanation": "Missing variables are added by multiplying with (variable + variable') and then expanding."
        },
        {
          "q": "Convert to canonical SOP form: F(A,B) = A' + B'",
          "marks": 2,
          "original": "A' + B'",
          "variables": 2,
          "canonical": "A'B' + A'B + AB'",
          "minterms": "m0, m1, m2",
          "steps": [
            { "step": 1, "action": "Original expression", "expression": "F = A' + B'", "law": "Given" },
            { "step": 2, "action": "Expand A'", "expression": "A' = A'(B + B') = A'B + A'B'", "law": "Identity Law" },
            { "step": 3, "action": "Expand B'", "expression": "B' = B'(A + A') = AB' + A'B'", "law": "Identity Law" },
            { "step": 4, "action": "Combine terms", "expression": "F = A'B + A'B' + AB' + A'B'", "law": "Substitution" },
            { "step": 5, "action": "Remove duplicate A'B'", "expression": "F = A'B' + A'B + AB'", "law": "Idempotent Law" },
            { "step": 6, "action": "Final canonical SOP", "expression": "F = A'B' + A'B + AB'", "law": "Canonical form" }
          ],
          "explanation": "Each term is expanded by including the missing variable and its complement."
        },
        {
          "q": "Convert to canonical SOP form: F(A,B) = AB'",
          "marks": 2,
          "original": "AB'",
          "variables": 2,
          "canonical": "AB'",
          "minterms": "m2",
          "steps": [
            { "step": 1, "action": "Original expression", "expression": "F = AB'", "law": "Given" },
            { "step": 2, "action": "Check if canonical", "expression": "Both A and B appear", "law": "Observation" },
            { "step": 3, "action": "Already in canonical form", "expression": "F = AB'", "law": "Canonical form" }
          ],
          "explanation": "Since both variables appear in the term, it's already a minterm and hence canonical."
        },
        {
          "q": "Convert to canonical SOP form: F(A,B) = (A + B')(A' + B)",
          "marks": 2,
          "original": "(A + B')(A' + B)",
          "variables": 2,
          "canonical": "AB + A'B'",
          "minterms": "m0, m3",
          "steps": [
            { "step": 1, "action": "Original expression (POS form)", "expression": "F = (A + B')(A' + B)", "law": "Given" },
            { "step": 2, "action": "Convert to SOP first", "expression": "Expand: A·A' + A·B + B'·A' + B'·B", "law": "Distributive Law" },
            { "step": 3, "action": "Simplify", "expression": "0 + AB + A'B' + 0 = AB + A'B'", "law": "Complement & Idempotent" },
            { "step": 4, "action": "Check if canonical", "expression": "Both terms have both variables", "law": "Observation" },
            { "step": 5, "action": "Already canonical", "expression": "F = AB + A'B'", "law": "Canonical SOP" }
          ],
          "explanation": "First convert POS to SOP, then verify each term has all variables."
        },
        {
          "q": "Convert to canonical SOP form: F(A,B) = (A ⊕ B)",
          "marks": 2,
          "original": "A ⊕ B",
          "variables": 2,
          "canonical": "A'B + AB'",
          "minterms": "m1, m2",
          "steps": [
            { "step": 1, "action": "Original XOR expression", "expression": "F = A ⊕ B", "law": "Given" },
            { "step": 2, "action": "Convert XOR to SOP", "expression": "A ⊕ B = A'B + AB'", "law": "XOR definition" },
            { "step": 3, "action": "Check canonical form", "expression": "Both terms have both variables", "law": "Observation" },
            { "step": 4, "action": "Already canonical", "expression": "F = A'B + AB'", "law": "Canonical SOP" }
          ],
          "explanation": "XOR naturally gives canonical SOP form with two minterms."
        }
      ]
    },

    {
      "section": "B",
      "type": "3-Variable SOP to Canonical (3 Marks Each)",
      "marksPerQuestion": 3,
      "totalQuestions": 5,
      "questions": [
        {
          "q": "Convert to canonical SOP form: F(A,B,C) = A + BC",
          "marks": 3,
          "original": "A + BC",
          "variables": 3,
          "canonical": "A'B'C + A'BC' + A'BC + AB'C' + AB'C + ABC' + ABC",
          "minterms": "m1, m2, m3, m4, m5, m6, m7",
          "steps": [
            { "step": 1, "action": "Original expression", "expression": "F = A + BC", "law": "Given" },
            { "step": 2, "action": "Expand A with missing B and C", "expression": "A = A(B + B')(C + C') = A(BC + BC' + B'C + B'C')", "law": "Identity Law (X = X·1·1)" },
            { "step": 3, "action": "Expand", "expression": "A = ABC + ABC' + AB'C + AB'C'", "law": "Distributive Law" },
            { "step": 4, "action": "Expand BC with missing A", "expression": "BC = BC(A + A') = ABC + A'BC", "law": "Identity Law" },
            { "step": 5, "action": "Combine all terms", "expression": "F = ABC + ABC' + AB'C + AB'C' + ABC + A'BC", "law": "Substitution" },
            { "step": 6, "action": "Remove duplicate ABC", "expression": "F = ABC + ABC' + AB'C + AB'C' + A'BC", "law": "Idempotent Law" },
            { "step": 7, "action": "Final canonical SOP", "expression": "F = A'BC + AB'C' + AB'C + ABC' + ABC", "law": "Canonical form" }
          ],
          "explanation": "Each product term is expanded to include all three variables."
        },
        {
          "q": "Convert to canonical SOP form: F(A,B,C) = AB + AC + BC",
          "marks": 3,
          "original": "AB + AC + BC",
          "variables": 3,
          "canonical": "ABC' + AB'C + A'BC + ABC",
          "minterms": "m3, m5, m6, m7",
          "steps": [
            { "step": 1, "action": "Original expression", "expression": "F = AB + AC + BC", "law": "Given" },
            { "step": 2, "action": "Expand AB with missing C", "expression": "AB = AB(C + C') = ABC + ABC'", "law": "Identity Law" },
            { "step": 3, "action": "Expand AC with missing B", "expression": "AC = AC(B + B') = ABC + AB'C", "law": "Identity Law" },
            { "step": 4, "action": "Expand BC with missing A", "expression": "BC = BC(A + A') = ABC + A'BC", "law": "Identity Law" },
            { "step": 5, "action": "Combine all terms", "expression": "F = ABC + ABC' + ABC + AB'C + ABC + A'BC", "law": "Substitution" },
            { "step": 6, "action": "Remove duplicates", "expression": "F = ABC' + AB'C + A'BC + ABC", "law": "Idempotent Law (ABC appears 3 times → once)" },
            { "step": 7, "action": "Final canonical SOP", "expression": "F = A'BC + AB'C + ABC' + ABC", "law": "Canonical form" }
          ],
          "explanation": "This is the majority function expressed in canonical SOP."
        },
        {
          "q": "Convert to canonical SOP form: F(A,B,C) = A'B + B'C + C'A",
          "marks": 3,
          "original": "A'B + B'C + C'A",
          "variables": 3,
          "canonical": "A'BC' + A'BC + AB'C + ABC'",
          "minterms": "m2, m3, m5, m6",
          "steps": [
            { "step": 1, "action": "Original expression", "expression": "F = A'B + B'C + C'A", "law": "Given" },
            { "step": 2, "action": "Expand A'B with missing C", "expression": "A'B = A'B(C + C') = A'BC + A'BC'", "law": "Identity Law" },
            { "step": 3, "action": "Expand B'C with missing A", "expression": "B'C = B'C(A + A') = AB'C + A'B'C", "law": "Identity Law" },
            { "step": 4, "action": "Expand C'A with missing B", "expression": "C'A = C'A(B + B') = ABC' + AB'C'", "law": "Identity Law" },
            { "step": 5, "action": "Combine all terms", "expression": "F = A'BC + A'BC' + AB'C + A'B'C + ABC' + AB'C'", "law": "Substitution" },
            { "step": 6, "action": "Remove terms with missing variables", "expression": "F = A'BC' + A'BC + AB'C + ABC'", "law": "Keep only terms with all variables" },
            { "step": 7, "action": "Final canonical SOP", "expression": "F = A'BC' + A'BC + AB'C + ABC'", "law": "Canonical form" }
          ],
          "explanation": "Only terms with all three variables are kept in canonical form."
        },
        {
          "q": "Convert to canonical SOP form: F(A,B,C) = (A ⊕ B) + C",
          "marks": 3,
          "original": "(A ⊕ B) + C",
          "variables": 3,
          "canonical": "A'B'C + A'BC' + A'BC + AB'C' + AB'C + ABC",
          "minterms": "m1, m2, m3, m4, m5, m7",
          "steps": [
            { "step": 1, "action": "Original expression", "expression": "F = (A ⊕ B) + C", "law": "Given" },
            { "step": 2, "action": "Convert XOR to SOP", "expression": "A ⊕ B = A'B + AB'", "law": "XOR definition" },
            { "step": 3, "action": "Expression becomes", "expression": "F = A'B + AB' + C", "law": "Substitution" },
            { "step": 4, "action": "Expand A'B with missing C", "expression": "A'B = A'B(C + C') = A'BC + A'BC'", "law": "Identity Law" },
            { "step": 5, "action": "Expand AB' with missing C", "expression": "AB' = AB'(C + C') = AB'C + AB'C'", "law": "Identity Law" },
            { "step": 6, "action": "Expand C with missing A and B", "expression": "C = C(A + A')(B + B') = ABC + AB'C + A'BC + A'B'C", "law": "Identity Law (X = X·1·1)" },
            { "step": 7, "action": "Combine all terms", "expression": "F = A'BC + A'BC' + AB'C + AB'C' + ABC + AB'C + A'BC + A'B'C", "law": "Substitution" },
            { "step": 8, "action": "Remove duplicates", "expression": "F = A'B'C + A'BC' + A'BC + AB'C' + AB'C + ABC", "law": "Idempotent Law" },
            { "step": 9, "action": "Final canonical SOP", "expression": "F = A'B'C + A'BC' + A'BC + AB'C' + AB'C + ABC", "law": "Canonical form" }
          ],
          "explanation": "All terms are expanded to include all three variables."
        },
        {
          "q": "Convert to canonical SOP form: F(A,B,C) = (A + B')(B + C')",
          "marks": 3,
          "original": "(A + B')(B + C')",
          "variables": 3,
          "canonical": "AB'C' + ABC' + A'B'C' + A'BC'",
          "minterms": "m0, m2, m4, m6",
          "steps": [
            { "step": 1, "action": "Original POS expression", "expression": "F = (A + B')(B + C')", "law": "Given" },
            { "step": 2, "action": "Convert to SOP by expansion", "expression": "= A·B + A·C' + B'·B + B'·C'", "law": "Distributive Law" },
            { "step": 3, "action": "Simplify", "expression": "= AB + AC' + 0 + B'C' = AB + AC' + B'C'", "law": "Complement Law (B'B = 0)" },
            { "step": 4, "action": "Expand AB with missing C", "expression": "AB = AB(C + C') = ABC + ABC'", "law": "Identity Law" },
            { "step": 5, "action": "Expand AC' with missing B", "expression": "AC' = AC'(B + B') = ABC' + AB'C'", "law": "Identity Law" },
            { "step": 6, "action": "Expand B'C' with missing A", "expression": "B'C' = B'C'(A + A') = AB'C' + A'B'C'", "law": "Identity Law" },
            { "step": 7, "action": "Combine terms", "expression": "F = ABC + ABC' + ABC' + AB'C' + AB'C' + A'B'C'", "law": "Substitution" },
            { "step": 8, "action": "Remove duplicates", "expression": "F = ABC + ABC' + AB'C' + A'B'C'", "law": "Idempotent Law" },
            { "step": 9, "action": "Final canonical SOP", "expression": "F = A'B'C' + AB'C' + ABC' + ABC", "law": "Canonical form" }
          ],
          "explanation": "First convert from POS to SOP, then expand each term to include the missing variable."
        }
      ]
    },

    {
