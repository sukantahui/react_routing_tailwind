          "original": "(A ⊕ B)(C ⊕ D)",
          "variables": 4,
          "canonical": "A'B'C'D' + A'B'CD + AB'C'D + AB'CD' + A'BC'D' + A'BCD + ABC'D + ABCD'",
          "minterms": "m0, m3, m5, m6, m9, m10, m12, m15",
