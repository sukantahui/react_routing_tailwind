      "questions": [
        {
          "q": "Simplify using Boolean laws: A + A'B + AB'",
          "marks": 2,
          "original": "A + A'B + AB'",
          "simplified": "A + B",
          "steps": [
            { "step": 1, "action": "Original expression", "expression": "F = A + A'B + AB'", "law": "Given" },
            { "step": 2, "action": "Group A + A'B", "expression": "A + A'B = (A + A')(A + B) = A + B", "law": "Distributive & Complement" },
            { "step": 3, "action": "Expression becomes", "expression": "A + B + AB'", "law": "Substitution" },
            { "step": 4, "action": "Apply Absorption", "expression": "A + B", "law": "A + AB' = A" }
          ],
          "explanation": "Using Distributive and Absorption laws."
        },
        {
          "q": "Simplify using Boolean laws: (A + B)(A + C)",
          "marks": 2,
          "original": "(A + B)(A + C)",
          "simplified": "A + BC",
          "steps": [
            { "step": 1, "action": "Expand", "expression": "AA + AC + BA + BC", "law": "Distributive Law" },
            { "step": 2, "action": "Simplify", "expression": "A + AC + AB + BC", "law": "AA = A" },
            { "step": 3, "action": "Factor A", "expression": "A(1 + C + B) + BC", "law": "Distributive Law" },
            { "step": 4, "action": "Apply Null Law", "expression": "A·1 + BC = A + BC", "law": "1 + X = 1" }
          ],
          "explanation": "This is the reverse of the distributive law."
        },
        {
          "q": "Simplify using Boolean laws: AB + A'C + BC",
          "marks": 2,
          "original": "AB + A'C + BC",
          "simplified": "AB + A'C",
          "steps": [
            { "step": 1, "action": "Original expression", "expression": "F = AB + A'C + BC", "law": "Given" },
            { "step": 2, "action": "Apply Consensus Theorem", "expression": "BC is redundant", "law": "Consensus Theorem" },
            { "step": 3, "action": "Remove redundant term", "expression": "AB + A'C", "law": "Simplification" }
          ],
          "explanation": "BC is the consensus term and can be eliminated."
        },
        {
          "q": "Simplify using Boolean laws: (A ⊕ B) ⊕ (A ⊕ C)",
          "marks": 2,
          "original": "(A ⊕ B) ⊕ (A ⊕ C)",
          "simplified": "B ⊕ C",
          "steps": [
            { "step": 1, "action": "XOR is associative", "expression": "(A ⊕ B) ⊕ (A ⊕ C) = A ⊕ B ⊕ A ⊕ C", "law": "Associative Law" },
            { "step": 2, "action": "Rearrange", "expression": "A ⊕ A ⊕ B ⊕ C", "law": "Commutative Law" },
            { "step": 3, "action": "A ⊕ A = 0", "expression": "0 ⊕ B ⊕ C = B ⊕ C", "law": "XOR property" }
          ],
          "explanation": "XOR of a variable with itself cancels out."
        },
        {
          "q": "Simplify using Boolean laws: (X + Y)(X' + Z)(Y + Z)",
          "marks": 2,
          "original": "(X + Y)(X' + Z)(Y + Z)",
          "simplified": "(X + Y)(X' + Z)",
          "steps": [
            { "step": 1, "action": "Original expression", "expression": "(X+Y)(X'+Z)(Y+Z)", "law": "Given" },
            { "step": 2, "action": "Apply Consensus Theorem (dual)", "expression": "(Y+Z) is the consensus term", "law": "Consensus Theorem" },
            { "step": 3, "action": "Remove redundant term", "expression": "(X+Y)(X'+Z)", "law": "Simplification" }
          ],
          "explanation": "The term (Y+Z) is redundant by the dual consensus theorem."
        }
      ]
