      "questions": [
        {
          "q": "State De Morgan's Theorems.",
          "marks": 1,
          "answer": "(A + B)' = A'·B' and (A·B)' = A' + B'",
          "steps": [
            { "step": 1, "action": "First Theorem", "expression": "Complement of OR = AND of complements", "law": "De Morgan" },
            { "step": 2, "action": "Second Theorem", "expression": "Complement of AND = OR of complements", "law": "De Morgan" }
          ],
          "explanation": "De Morgan's theorems are fundamental for complementing Boolean expressions."
        },
        {
          "q": "Define Minterm and Maxterm with example.",
          "marks": 1,
          "answer": "Minterm: Product term where all variables appear once (e.g., A'BC). Maxterm: Sum term where all variables appear once (e.g., A+B'+C).",
          "steps": [
            { "step": 1, "action": "Minterm definition", "expression": "AND of all variables", "law": "Definition" },
            { "step": 2, "action": "Maxterm definition", "expression": "OR of all variables", "law": "Definition" }
          ],
          "explanation": "For n variables, there are 2^n minterms and 2^n maxterms."
        },
        {
          "q": "What is Duality Principle?",
          "marks": 1,
          "answer": "Replacing + with ·, · with +, 0 with 1, and 1 with 0 gives the dual expression.",
          "steps": [
            { "step": 1, "action": "Duality operation", "expression": "Interchange AND/OR and 0/1", "law": "Duality Principle" }
          ],
          "explanation": "If an expression is valid, its dual is also valid."
        },
        {
          "q": "What is the difference between Canonical and Standard form?",
          "marks": 1,
          "answer": "Canonical form has all variables in each term; Standard form may have missing variables.",
          "steps": [
            { "step": 1, "action": "Canonical form", "expression": "All variables appear in each term", "law": "Definition" },
            { "step": 2, "action": "Standard form", "expression": "Variables may be missing", "law": "Definition" }
          ],
          "explanation": "Canonical is a subset of Standard form."
        },
        {
          "q": "State the Consensus Theorem.",
          "marks": 1,
          "answer": "AB + A'C + BC = AB + A'C and (A+B)(A'+C)(B+C) = (A+B)(A'+C)",
          "steps": [
            { "step": 1, "action": "First form", "expression": "AB + A'C + BC = AB + A'C", "law": "Consensus Theorem" },
            { "step": 2, "action": "Dual form", "expression": "(A+B)(A'+C)(B+C) = (A+B)(A'+C)", "law": "Consensus Theorem" }
          ],
          "explanation": "The consensus term BC is redundant when both AB and A'C are present."
        }
      ]
    },
    {
