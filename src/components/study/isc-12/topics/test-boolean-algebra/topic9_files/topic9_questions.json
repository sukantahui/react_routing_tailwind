    {
      "section": "C",
      "type": "Complement of Expressions (2 Marks Each)",
      "marksPerQuestion": 2,
      "totalQuestions": 5,
      "questions": [
        {
          "q": "Find the complement of: F = A + B'C",
          "marks": 2,
          "original": "A + B'C",
          "complement": "A'·(B + C')",
          "steps": [
            { "step": 1, "action": "Apply De Morgan's Theorem", "expression": "(A + B'C)' = A'·(B'C)'", "law": "(X+Y)' = X'·Y'" },
            { "step": 2, "action": "Apply De Morgan's again", "expression": "A'·(B + C')", "law": "(X·Y)' = X' + Y'" }
          ],
          "explanation": "Complement of OR is AND of complements."
        },
        {
          "q": "Find the complement of: F = (A + B)(A' + C)",
          "marks": 2,
          "original": "(A + B)(A' + C)",
          "complement": "A'B' + AC'",
          "steps": [
            { "step": 1, "action": "Apply De Morgan's Theorem", "expression": "[(A+B)(A'+C)]' = (A+B)' + (A'+C)'", "law": "(X·Y)' = X' + Y'" },
            { "step": 2, "action": "Apply De Morgan's to each", "expression": "A'B' + AC'", "law": "(X+Y)' = X'·Y'" }
          ],
          "explanation": "Complement of POS becomes SOP of complements."
        },
        {
          "q": "Find the complement of: F = AB' + A'B",
          "marks": 2,
          "original": "AB' + A'B",
          "complement": "AB + A'B'",
          "steps": [
            { "step": 1, "action": "This is XOR function", "expression": "F = A ⊕ B", "law": "XOR definition" },
            { "step": 2, "action": "Complement of XOR is XNOR", "expression": "F' = A ⊙ B = AB + A'B'", "law": "XNOR definition" }
          ],
          "explanation": "XOR is NOT self-complement; its complement is XNOR."
        },
        {
          "q": "Find the complement of: F = AB + CD",
          "marks": 2,
          "original": "AB + CD",
          "complement": "(A' + B')(C' + D')",
          "steps": [
            { "step": 1, "action": "Apply De Morgan's Theorem", "expression": "(AB + CD)' = (AB)'·(CD)'", "law": "(X+Y)' = X'·Y'" },
            { "step": 2, "action": "Apply De Morgan's to each", "expression": "(A' + B')(C' + D')", "law": "(X·Y)' = X' + Y'" }
          ],
          "explanation": "Complement of SOP becomes POS of complements."
        },
        {
          "q": "Find the complement of: F = (A⊕B) + (C⊕D)",
          "marks": 2,
          "original": "(A⊕B) + (C⊕D)",
          "complement": "(A⊙B) · (C⊙D)",
          "steps": [
            { "step": 1, "action": "Apply De Morgan's", "expression": "[(A⊕B)+(C⊕D)]' = (A⊕B)' · (C⊕D)'", "law": "(X+Y)' = X'·Y'" },
            { "step": 2, "action": "Complement each XOR", "expression": "(A⊙B)·(C⊙D)", "law": "XOR complement = XNOR" }
          ],
          "explanation": "Complement of OR of XORs is AND of XNORs."
        }
      ]
    },
