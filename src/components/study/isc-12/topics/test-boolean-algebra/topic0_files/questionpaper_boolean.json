      "questions": [
        {
          "q": "Simplify the Boolean expression using K-map:\nF(A,B,C) = Σ(1,2,3,5)",
          "marks": 10,
          "original": "F(A,B,C) = Σ(1,2,3,5)",
          "variables": 3,
          "minterms": "m1, m2, m3, m5",
          "canonical": "A'B'C + A'BC' + A'BC + AB'C",
          "simplified": "A'B + A'C + B'C",
          "kmap": {
            "rows": ["00", "01", "11", "10"],
            "headers": ["BC", "A=0", "A=1"],
            "cells": [
              {"position": "0-00", "value": 0, "minterm": "m0", "grouped": false},
              {"position": "0-01", "value": 1, "minterm": "m1", "grouped": true},
              {"position": "0-11", "value": 1, "minterm": "m3", "grouped": true},
              {"position": "0-10", "value": 1, "minterm": "m2", "grouped": true},
              {"position": "1-00", "value": 0, "minterm": "m4", "grouped": false},
              {"position": "1-01", "value": 1, "minterm": "m5", "grouped": true},
              {"position": "1-11", "value": 0, "minterm": "m7", "grouped": false},
              {"position": "1-10", "value": 0, "minterm": "m6", "grouped": false}
            ]
          },
          "steps": [
            { "step": 1, "action": "Write the minterm list", "expression": "F = Σ(1,2,3,5)", "law": "Given" },
            { "step": 2, "action": "Convert to binary", "expression": "m1=001, m2=010, m3=011, m5=101", "law": "Binary conversion" },
            { "step": 3, "action": "Draw 3-variable K-map", "expression": "Rows: A, Columns: BC (00,01,11,10)", "law": "K-map structure" },
            { "step": 4, "action": "Place 1's in cells", "expression": "m1 (A=0,BC=01), m2 (A=0,BC=10), m3 (A=0,BC=11), m5 (A=1,BC=01)", "law": "K-map placement" },
            { "step": 5, "action": "Group adjacent 1's", "expression": "Group 1: m1,m3 (A=0, B varies, C=1) → A'C", "law": "Grouping rule" },
            { "step": 6, "action": "Group 2: m2,m3 (A=0, B=1, C varies) → A'B", "law": "Grouping rule" },
            { "step": 7, "action": "Group 3: m1,m5 (C=1, A varies, B=0) → B'C", "law": "Grouping rule" },
            { "step": 8, "action": "Write simplified expression", "expression": "F = A'C + A'B + B'C", "law": "Sum of groups" },
            { "step": 9, "action": "Alternative simplified form", "expression": "F = A'B + A'C + B'C", "law": "Rearranged" }
          ],
          "explanation": "Using 3-variable K-map, we group adjacent 1's to get the minimal SOP expression: A'B + A'C + B'C. Students should draw the K-map and show grouping."
        }
      ]
