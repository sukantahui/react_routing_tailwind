{
  "examples": [
    {
      "id": 1,
      "name": "Example 1: P'Q + PQ' + P'Q'",
      "original": "P'Q + PQ' + P'Q'",
      "simplified": "(P·Q)'",
      "variables": ["P", "Q"],
      "steps": [
        {"step": 1, "action": "Write the original expression", "expression": "F = P'Q + PQ' + P'Q'", "law": "Given"},
        {"step": 2, "action": "Group first and last terms: P'Q + P'Q'", "expression": "P'Q + P'Q' = P'(Q + Q')", "law": "Distributive Law (factoring)"},
        {"step": 3, "action": "Apply Complement Law: Q + Q' = 1", "expression": "P'(1) = P'", "law": "Complement Law"},
        {"step": 4, "action": "Now expression becomes: F = P' + PQ'", "expression": "F = P' + PQ'", "law": "Substitution"},
        {"step": 5, "action": "Apply Distributive Law: P' + PQ' = (P' + P)(P' + Q')", "expression": "(P' + P)(P' + Q')", "law": "Distributive Law: A + BC = (A+B)(A+C)"},
        {"step": 6, "action": "Apply Complement Law: P' + P = 1", "expression": "1·(P' + Q') = P' + Q'", "law": "Complement Law and Identity Law"},
        {"step": 7, "action": "Apply De Morgan's Theorem: P' + Q' = (P·Q)'", "expression": "(P·Q)'", "law": "De Morgan's Theorem"}
      ],
      "explanation": "This simplification uses distributive law, complement law, and De Morgan's theorem to reduce the expression to NAND form."
    },
    {
      "id": 2,
      "name": "Example 2: AB + A'C + BC",
      "original": "A·B + A'·C + B·C",
      "simplified": "A·B + A'·C",
      "variables": ["A", "B", "C"],
      "steps": [
        {"step": 1, "action": "Write the original expression", "expression": "F = AB + A'C + BC", "law": "Given"},
        {"step": 2, "action": "Add redundant term (A + A') to BC", "expression": "BC = BC·(A + A') = ABC + A'BC", "law": "Identity Law: X = X·1, and 1 = A + A'"},
        {"step": 3, "action": "Rewrite expression", "expression": "F = AB + A'C + ABC + A'BC", "law": "Substitution"},
        {"step": 4, "action": "Group terms: AB + ABC = AB(1 + C) = AB", "expression": "AB(1 + C) = AB", "law": "Distributive Law and Null Law"},
        {"step": 5, "action": "Group terms: A'C + A'BC = A'C(1 + B) = A'C", "expression": "A'C(1 + B) = A'C", "law": "Distributive Law and Null Law"},
        {"step": 6, "action": "Final simplified expression", "expression": "F = AB + A'C", "law": "Consensus Theorem"}
      ],
      "explanation": "This demonstrates the Consensus Theorem: AB + A'C + BC = AB + A'C. The term BC is redundant."
    },
    {
      "id": 3,
      "name": "Example 3: A + A'B",
      "original": "A + A'·B",
      "simplified": "A + B",
      "variables": ["A", "B"],
      "steps": [
        {"step": 1, "action": "Write the original expression", "expression": "F = A + A'B", "law": "Given"},
        {"step": 2, "action": "Apply Distributive Law: A + A'B = (A + A')(A + B)", "expression": "(A + A')(A + B)", "law": "Distributive Law: X + YZ = (X+Y)(X+Z)"},
        {"step": 3, "action": "Apply Complement Law: A + A' = 1", "expression": "1·(A + B) = A + B", "law": "Complement Law and Identity Law"}
      ],
      "explanation": "This is the Absorption Law variation: A + A'B = A + B."
    },
    {
      "id": 4,
      "name": "Example 4: AB + AB'",
      "original": "A·B + A·B'",
      "simplified": "A",
      "variables": ["A", "B"],
      "steps": [
        {"step": 1, "action": "Write the original expression", "expression": "F = AB + AB'", "law": "Given"},
        {"step": 2, "action": "Factor out A", "expression": "A(B + B')", "law": "Distributive Law"},
        {"step": 3, "action": "Apply Complement Law: B + B' = 1", "expression": "A·1 = A", "law": "Complement Law and Identity Law"}
      ],
      "explanation": "This simplifies by factoring out the common variable A."
    },
    {
