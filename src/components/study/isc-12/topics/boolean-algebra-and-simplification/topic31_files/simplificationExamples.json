        {"step": 3, "action": "Apply Idempotent Law: A·A = A", "expression": "A + AC + AB + BC", "law": "Idempotent Law"},
        {"step": 4, "action": "Factor A from first three terms", "expression": "A(1 + C + B) + BC", "law": "Distributive Law"},
        {"step": 5, "action": "Apply Null Law: 1 + C + B = 1", "expression": "A·1 + BC = A + BC", "law": "Null Law and Identity Law"}
