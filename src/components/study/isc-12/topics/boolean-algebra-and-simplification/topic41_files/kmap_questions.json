          "dc": [],
          "q": "Simplify F(A,B,C,D) = Σ(0,1,2,5,7,9,15) using a Karnaugh map.",
          "marks": 5,
          "answer": "A'B'C' + A'BD + A'B'CD' + ABC + AB'C'D",
          "steps": [
            { "step": 1, "action": "Place 1s in cells 0,1,2,5,7,9,15.", "cells": [0,1,2,5,7,9,15] },
            { "step": 2, "action": "Group cells 0 and 1 → A'B'C'", "cells": [0,1], "term": "A'B'C'", "law": "Adjacent horizontally" },
            { "step": 3, "action": "Group cells 1 and 5 → A'BD", "cells": [1,5], "term": "A'BD", "law": "Adjacent vertically" },
            { "step": 4, "action": "Group cell 2 alone → A'B'CD'", "cells": [2], "term": "A'B'CD'", "law": "Single cell" },
            { "step": 5, "action": "Group cells 7 and 15 → ABC", "cells": [7,15], "term": "ABC", "law": "Adjacent vertically" },
            { "step": 6, "action": "Group cell 9 alone → AB'C'D", "cells": [9], "term": "AB'C'D", "law": "Single cell" }
          ],
          "explanation": "All minterms are covered by these five product terms."
        },
