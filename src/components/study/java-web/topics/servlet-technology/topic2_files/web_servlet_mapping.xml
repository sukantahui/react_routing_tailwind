<web-app ...>
    <servlet>
        <servlet-name>StudentServlet</servlet-name>
        <servlet-class>com.school.StudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentServlet</servlet-name>
        <url-pattern>/students/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TeacherServlet</servlet-name>
        <servlet-class>com.school.TeacherServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TeacherServlet</servlet-name>
        <url-pattern>/teachers</url-pattern>
        <url-pattern>/staff/*</url-pattern>
    </servlet-mapping>
</web-app>